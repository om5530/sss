# ----- Server -----
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:4200

# ----- Database -----
# Local MongoDB, or a MongoDB Atlas connection string, e.g.
# mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/bakery_cafe
MONGODB_URI=mongodb://127.0.0.1:27017/bakery_cafe

# ----- Auth -----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (leave blank to disable Google login)
GOOGLE_CLIENT_ID=

# ----- Firebase Phone Auth (real production OTP) -----
# The client sends the OTP via Firebase; the server verifies the ID token.
# Get these from: Firebase console -> Project settings -> Service accounts
#   -> "Generate new private key" (downloads a JSON file).
# Leave blank to disable phone login and fall back to the mock OTP flow below.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the whole private key on one line with literal \n between lines, quoted:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ----- OTP (mock fallback — used only when Firebase above is not configured) -----
# "mock" prints the code to the server console and returns it in dev responses.
OTP_PROVIDER=mock
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_RESEND_COOLDOWN=30
# TEST DEPLOYMENTS ONLY: "true" returns mock OTP codes in API responses even in
# production, so a demo deploy is usable before Firebase SMS is set up. Anyone
# can then log in as any phone number — REMOVE before a real launch (the boot
# guard refuses to start if this is on alongside live payment keys).
EXPOSE_DEV_OTP=

# ----- Razorpay (preferred online-payment provider — UPI/cards/netbanking) -----
# Dashboard -> Account & Settings -> API keys. Webhook secret is set when you
# create the webhook (Dashboard -> Webhooks -> https://<api>/api/payments/razorpay-webhook,
# events: payment.captured, payment.failed).
# Leave blank to fall back to Stripe below, or to MOCK mode if both are blank.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ----- Stripe (legacy alternative; used only when Razorpay above is blank) -----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Image hosting (optional — Cloudinary; blank = images stored on this server's disk) -----
# cloudinary.com -> Dashboard -> cloud name / API key / API secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- Email notifications (optional — Resend; blank = notifications logged to console) -----
# resend.com -> API Keys. NOTIFY_FROM must be a verified sender/domain.
# SHOP_EMAIL receives new-order / enquiry / cake-request alerts.
RESEND_API_KEY=
NOTIFY_FROM=
SHOP_EMAIL=

# ----- Pricing -----
TAX_RATE=0.05
DELIVERY_FEE=40
CURRENCY=inr
